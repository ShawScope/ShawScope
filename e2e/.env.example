# Copy to .env.e2e (or export these vars in your shell) before running
# `npm run test:e2e`. Never commit real credentials -- this file is a
# template only.

# Base URL the tests run against. Defaults to the local dev server.
E2E_BASE_URL=http://localhost:5183

# Admin test account credentials. The admin-login spec falls back to a
# known test account if these are unset; only override when testing
# against a different environment/account. Get the real values from
# whoever manages the Supabase project -- do not hardcode them anywhere
# committed to this repo.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
